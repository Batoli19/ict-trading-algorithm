{
  "mt5": {
    "login":    12345678,
    "password": "YOUR_MT5_PASSWORD",
    "server":   "YOUR_BROKER_SERVER",
    "timeout":  10000
  },

  "pairs": ["EURUSD", "GBPUSD", "US30", "NAS100", "XAUUSD"],

  "timeframes": {
    "bias":   "H4",
    "entry":  "M15",
    "trigger":"M5"
  },

  "risk": {
    "risk_per_trade_pct":  1.0,
    "max_open_trades":     3,
    "max_daily_loss_pct":  3.0,
    "max_daily_trades":    10,
    "rr_ratio":            2.0,
    "trailing_stop":       true,
    "trailing_stop_pips":  15
  },

  "ict": {
    "fvg": {
      "enabled":          true,
      "min_gap_pips":     5,
      "mitigation_entry": true
    },
    "turtle_soup": {
      "enabled":          true,
      "lookback_candles": 20,
      "confirmation_pips": 3
    },
    "stop_hunt": {
      "enabled":          true,
      "equal_hl_tolerance": 2,
      "displacement_min_pips": 8
    },
    "kill_zones": {
      "enabled": true,
      "london_open":    { "start": "07:00", "end": "10:00", "tz": "UTC" },
      "ny_open":        { "start": "12:00", "end": "15:00", "tz": "UTC" },
      "london_close":   { "start": "15:00", "end": "17:00", "tz": "UTC" },
      "trade_only_in_kill_zones": true
    },
    "order_blocks": {
      "enabled":     true,
      "min_impulse_pips": 10
    }
  },

  "scalping": {
    "enabled":       true,
    "timeframe":     "M1",
    "max_spread_pips": 2.0,
    "quick_tp_pips": 10,
    "quick_sl_pips": 6
  },

  "news": {
    "enabled":       true,
    "provider":      "forexfactory",
    "avoid_minutes_before": 30,
    "avoid_minutes_after":  15,
    "impact_levels": ["HIGH"],
    "currencies":    ["USD", "EUR", "GBP"]
  },

  "notifications": {
    "enabled":       true,
    "telegram": {
      "enabled":     false,
      "bot_token":   "YOUR_TELEGRAM_BOT_TOKEN",
      "chat_id":     "YOUR_CHAT_ID"
    },
    "email": {
      "enabled":     false,
      "smtp_server": "smtp.gmail.com",
      "smtp_port":   587,
      "username":    "your@email.com",
      "password":    "YOUR_EMAIL_PASSWORD",
      "recipient":   "your@email.com"
    }
  },

  "dashboard": {
    "refresh_seconds": 5,
    "show_pnl":        true,
    "show_signals":    true
  }
}
